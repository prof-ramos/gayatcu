# Copie este arquivo para `.streamlit/secrets.toml` (local)
# ou configure os mesmos campos em Streamlit Cloud > Settings > Secrets.

[database]
# Supabase/PostgreSQL (recomendado para persistência em produção)
url = "postgresql+psycopg://<user>:<password>@<host>:6543/postgres?sslmode=require"

[backup]
# Fallback opcional em JSON remoto (presigned URL, R2/S3, etc.)
json_get_url = "https://<seu-endpoint>/backup.json"
json_put_url = "https://<seu-endpoint>/backup.json"
json_put_method = "PUT"

# Alternativa: variáveis de topo (também aceitas pelo app)
# DATABASE_URL = "postgresql+psycopg://..."
# BACKUP_JSON_GET_URL = "https://..."
# BACKUP_JSON_PUT_URL = "https://..."
# BACKUP_JSON_PUT_METHOD = "PUT"
